# Copy this file to .env and fill in your actual values. Do not commit .env to version control.

# Database Configuration
DB_HOST=localhost
DB_NAME=parkcastsg
DB_USER=your_db_user
DB_PASS=your_db_password

# CORS Configuration (critical for AWS deployment)
# Comma-separated list of allowed origins. No trailing spaces between entries.
# For local development:
CORS_ALLOW_ORIGINS=http://localhost:5173
# For AWS deployment, replace with your actual CloudFront/ALB/custom domain URLs, e.g.:
# CORS_ALLOW_ORIGINS=https://your-cloudfront-domain.cloudfront.net,https://your-domain.com

# Deployment Environment
# Set to "development", "staging", or "production"
ENVIRONMENT=development
