# Copy this file to .env and fill in your actual values. Do not commit .env to version control.

# Database Configuration
DB_HOST=localhost
DB_NAME=parkcastsg
DB_USER=your_db_user
DB_PASS=your_db_password

# --- PUBLIC CONFIGURATION ---
# Comma-separated list of allowed frontend origins.
# Local development frontend: http://localhost:5173
# Production (CloudFront): https://dmxr5wa316ehu.cloudfront.net
# Legacy S3 direct URL (kept for reference): http://parkcast-sg-web-ui.s3-website-ap-southeast-1.amazonaws.com
CORS_ALLOW_ORIGINS=http://localhost:5173,https://dmxr5wa316ehu.cloudfront.net

# Deployment Environment
# Set to "development", "staging", or "production"
ENVIRONMENT=development

